# Google Gemini API key (required). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated fallback models tried (in order) when the primary is rate-limited/overloaded
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-flash-latest

# SQLite database path (relative to backend/)
DATABASE_PATH=data/janmitra.db

# Directory where uploaded files are stored
UPLOAD_DIR=uploads

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
